CG_HOST=0.0.0.0
CG_PORT=8420
CG_DEBUG=false
CG_REPOSITORY_BACKEND=memory
CG_NEO4J_URI=bolt://localhost:7687
CG_NEO4J_USER=neo4j
CG_NEO4J_PASSWORD=contextgraph
CG_TRUST_THRESHOLD=0.65
CG_DEFAULT_CLAIM_TTL_DAYS=30
CG_ENABLE_FEDERATION=false
CG_ENABLE_BACKGROUND_WORKER=false
CG_BACKGROUND_WORKER_POLL_SECONDS=0.1
CG_WEBHOOK_TIMEOUT_SECONDS=5.0
CG_DELIVERY_MAX_ATTEMPTS=3
CG_DELIVERY_RETRY_BASE_SECONDS=0.5
CG_ENABLE_CLAIM_EXPIRY_SWEEPS=true
CG_CLAIM_EXPIRY_SWEEP_SECONDS=30.0

# Security: Set this to gate agent registration behind an admin key.
# When set, POST /v1/agents/register requires X-Admin-Key: <value>.
# Leave empty to allow open registration (development only).
CG_ADMIN_KEY=

# CORS: Comma-separated allowed origins, or * for all.
CG_CORS_ORIGINS=*

# Rate limiting: Max requests per minute per API key.
CG_RATE_LIMIT_PER_MINUTE=60

# x402 Payments
CG_ENABLE_PAYMENTS=false
CG_DEFAULT_CLAIM_PRICE=0.0
CG_PAYMENT_CURRENCY=USDC
CG_X402_VERIFIER_URL=

# ERC-8004 Identity
CG_ENABLE_IDENTITY=false
CG_ERC8004_REGISTRY_URL=

# Federation & A2A
CG_FEDERATION_NODE_ID=
CG_FEDERATION_PEERS=
CG_FEDERATION_KEY=
CG_ENABLE_A2A=false
CG_A2A_BASE_URL=

# LLM Extraction (optional - falls back to rule-based extraction)
CG_LLM_API_KEY=
CG_LLM_MODEL=claude-sonnet-4-6
CG_LLM_BASE_URL=https://api.anthropic.com
